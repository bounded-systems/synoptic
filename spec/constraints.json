      "$value": { "standard": "WCAG", "version": "2.2", "date": "2023-10-05", "sc": "1.4.6", "name": "Contrast (Enhanced)", "level": "AAA", "kind": "text", "ratio": { "text": 7.0, "largeText": 4.5 }, "url": "https://www.w3.org/TR/WCAG22/#contrast-enhanced" }
    },
    "wcag-2_2-1_4_11-AA": {
      "$type": "contrast-requirement",
      "$value": { "standard": "WCAG", "version": "2.2", "date": "2023-10-05", "sc": "1.4.11", "name": "Non-text Contrast", "level": "AA", "kind": "non-text", "ratio": { "nonText": 3.0 }, "url": "https://www.w3.org/TR/WCAG22/#non-text-contrast" }

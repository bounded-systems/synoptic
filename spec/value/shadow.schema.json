{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bounded.tools/synoptic/spec/value/shadow.schema.json",
  "title": "Shadow",
  "description": "A composite shadow (CSS Backgrounds 3 §7 box-shadow / DTCG shadow). A STRUCTURE of typed sub-atoms — offsets + optional color (defaults to currentColor) + blur + spread + inset — so the shadow atom is a MERKLE of its sub-atoms (each itself a value atom).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$type": {
      "const": "shadow"
    },
    "color": {
      "$ref": "color.schema.json"
    },
    "offsetX": {
      "$ref": "dimension.schema.json"
    },
    "offsetY": {
      "$ref": "dimension.schema.json"
    },
    "blur": {
      "$ref": "dimension.schema.json"
    },
    "spread": {
      "$ref": "dimension.schema.json"
    },
    "inset": {
      "type": "boolean",
      "description": "inner shadow (CSS Backgrounds 3)."
    }
  },
  "required": [
    "$type",
    "offsetX",
    "offsetY"
  ]
}
